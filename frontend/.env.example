# ─── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# ─── Backend API ───────────────────────────────────────────────────────────────
# URL of the deployed Python/Flask backend (leave blank to use mock data only)
NEXT_PUBLIC_API_URL=https://your-backend.railway.app

# ─── Mantle Network ────────────────────────────────────────────────────────────
NEXT_PUBLIC_MANTLE_CHAIN_ID=5000
NEXT_PUBLIC_MANTLE_RPC_URL=https://rpc.mantle.xyz
NEXT_PUBLIC_MANTLE_TESTNET_CHAIN_ID=5003
NEXT_PUBLIC_MANTLE_TESTNET_RPC_URL=https://rpc.sepolia.mantle.xyz

# ─── WalletConnect ─────────────────────────────────────────────────────────────
# Get a project ID from: https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# ─── Smart Contract Addresses (Mantle Testnet — deployed 2026-05-11) ───────────
NEXT_PUBLIC_MANDATE_POLICY_CONTRACT=0xee9FBcb6583B32d0ddC615882d0A03DA8714b952
NEXT_PUBLIC_AGENT_EXECUTOR_CONTRACT=0xEa15a627e1EADf5c3D09b641295CFD037BaaA4B7
NEXT_PUBLIC_RISK_GUARD_CONTRACT=0x5d7E824D8A374aA2b8ACe225220Ad7246a81e258

# ─── Server-side only (Vercel environment variables, NOT prefixed NEXT_PUBLIC) ──
# These are used inside /app/api/* serverless route handlers — never exposed to browser
OPENROUTER_API_KEY=sk-or-v1-...
BYBIT_API_KEY=your-bybit-read-only-key
BYBIT_API_SECRET=your-bybit-read-only-secret
