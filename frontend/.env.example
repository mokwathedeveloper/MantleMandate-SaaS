# ─── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side only — bypasses RLS. Not currently used by any route, kept for
# future admin/server-side operations. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Backend API ───────────────────────────────────────────────────────────────
# URL of the deployed Python/Flask backend (leave blank to use mock data only)
NEXT_PUBLIC_API_URL=

# ─── Mantle Network ────────────────────────────────────────────────────────────
NEXT_PUBLIC_MANTLE_CHAIN_ID=5000
NEXT_PUBLIC_MANTLE_RPC_URL=https://rpc.mantle.xyz
NEXT_PUBLIC_MANTLE_TESTNET_CHAIN_ID=5003
NEXT_PUBLIC_MANTLE_TESTNET_RPC_URL=https://rpc.sepolia.mantle.xyz

# ─── WalletConnect ─────────────────────────────────────────────────────────────
# Get a project ID from: https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ─── Smart Contract Addresses (Mantle Testnet — deployed 2026-05-11) ───────────
NEXT_PUBLIC_MANDATE_POLICY_CONTRACT=0x690Ab021b40a01E9f3818CdBa149fb5721480871
NEXT_PUBLIC_AGENT_EXECUTOR_CONTRACT=0xbC8419baDaa69649940F2D4dDC01a2CFDEb408f6
NEXT_PUBLIC_RISK_GUARD_CONTRACT=0x8D99D4F922248852Bc678bd4018F9f3E4576E34B

# ─── Mock AMM (Mantle Testnet — deployed 2026-06-10) ────────────────────────────
# mUSD/mWETH constant-product swap pool used for real on-chain agent execution
# (Merchant Moe / Agni Finance have no Sepolia testnet deployment to swap against).
NEXT_PUBLIC_MOCK_USD_CONTRACT=0x61806e0D29b0aa200dC26e9C1F0380707a3210c9
NEXT_PUBLIC_MOCK_WETH_CONTRACT=0x535DC64B3eBDf3ce0ed1C03a8dfbEaf3A84e49EF
NEXT_PUBLIC_SWAP_POOL_CONTRACT=0x3440d742bbbAe391b95E40FAF62d7a715582a4ad

# ─── Mantle Explorer (optional — defaults to mainnet/testnet public URLs) ───────
NEXT_PUBLIC_MANTLE_TESTNET_EXPLORER=https://explorer.sepolia.mantle.xyz

# ─── Server-side only (set in Vercel dashboard, NOT prefixed NEXT_PUBLIC) ───────
# Used inside /app/api/* serverless route handlers — never exposed to the browser
OPENROUTER_API_KEY=
BYBIT_API_KEY=
BYBIT_API_SECRET=

# Platform service wallet (Mantle Sepolia testnet) — registers shadow on-chain
# agents and submits executeOrder() transactions on a user's behalf when they
# run a trading cycle. Must be funded with testnet MNT for gas.
MANTLE_PRIVATE_KEY=

# Merchant Moe subgraph (optional — override for staging or custom deployments)
MANTLE_SUBGRAPH_URL=https://api.studio.thegraph.com/query/44992/merchant-moe-lb-mantle/version/latest
