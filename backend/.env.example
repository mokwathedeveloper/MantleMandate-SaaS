# Copy this file to .env and fill in your values
# NEVER commit .env to git

FLASK_ENV=development
SECRET_KEY=
JWT_SECRET_KEY=

# Database (matches docker-compose.yml defaults)
DATABASE_URL=

# Redis
REDIS_URL=

# AI — Mandate parser + agent loop (get key from openrouter.ai)
OPENROUTER_API_KEY=

# Market data — Bybit read-only keys (no trading permissions needed)
BYBIT_API_KEY=
BYBIT_API_SECRET=

# Blockchain — Mantle Network
MANTLE_RPC_URL=https://rpc.mantle.xyz
MANTLE_TESTNET_RPC_URL=https://rpc.sepolia.mantle.xyz
MANTLE_PRIVATE_KEY=

# Deployed contract addresses (Mantle Testnet — deployed 2026-05-11)
MANDATE_POLICY_CONTRACT=0xee9FBcb6583B32d0ddC615882d0A03DA8714b952
AGENT_EXECUTOR_CONTRACT=0xEa15a627e1EADf5c3D09b641295CFD037BaaA4B7
RISK_GUARD_CONTRACT=0x5d7E824D8A374aA2b8ACe225220Ad7246a81e258

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:3000,https://mantlemandate.vercel.app

# AWS S3 (for report exports — optional in dev)
AWS_S3_BUCKET=mantlemandate-reports
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
