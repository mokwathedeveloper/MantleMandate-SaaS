# Copy this file to .env and fill in your values
# NEVER commit .env to git

FLASK_ENV=development
SECRET_KEY=change-this-to-a-random-secret-key
JWT_SECRET_KEY=change-this-to-a-random-jwt-secret

# Database (matches docker-compose.yml defaults)
DATABASE_URL=postgresql://mantlemandate:devpassword@localhost:5432/mantlemandate

# Redis (matches docker-compose.yml defaults)
REDIS_URL=redis://localhost:6379/0

# AI — Mandate parser + agent loop (get key from openrouter.ai)
OPENROUTER_API_KEY=sk-or-v1-...

# Market data — Bybit read-only keys (no trading permissions needed)
BYBIT_API_KEY=your-bybit-read-only-key
BYBIT_API_SECRET=your-bybit-read-only-secret

# Blockchain — Mantle Network
MANTLE_RPC_URL=https://rpc.mantle.xyz
MANTLE_TESTNET_RPC_URL=https://rpc.sepolia.mantle.xyz
MANTLE_PRIVATE_KEY=0x...   # Agent execution wallet — never use your main wallet

# Deployed contract addresses (fill after deployment)
MANDATE_POLICY_CONTRACT=0x
AGENT_EXECUTOR_CONTRACT=0x
RISK_GUARD_CONTRACT=0x

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:3000,https://mantlemandate.vercel.app

# AWS S3 (for report exports — optional in dev)
AWS_S3_BUCKET=mantlemandate-reports
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
